# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.metadata
.pub-cache/
.pub/
/build/
/coverage/
# Flutter Rust Bridge generated files
*.frb.dart
ios/Runner/bridge_generated.h

# Android local properties (contains paths that vary by installation location)
android/local.properties

# Task execution logs
logs/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android native libraries (built locally)
android/app/src/main/jniLibs/

# Python virtual environment
scripts/.venv/

# Rust coverage reports
rust/coverage/

# Spec workflow (generated artifacts)
.spec-workflow/

# Generated plugin registrants
ios/Runner/GeneratedPluginRegistrant.*
android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java
linux/flutter/generated_plugin_registrant.*
linux/flutter/generated_plugins.cmake

# iOS/Flutter generated
ios/Flutter/Generated.xcconfig
ios/Flutter/ephemeral/
ios/Flutter/flutter_export_environment.sh

# iOS native libraries (built locally)
ios/Libs/

# Flutter dependency lockfile (regenerated by `flutter pub get`)
pubspec.lock

# Rust build artifacts
rust/target/

# Android build artifacts
android/app/libs/

# Temporary test data
test_plan.json
